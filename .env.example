# 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# ==================== 测试环境配置 ====================
# UAT 环境
UAT_USERNAME=your_uat_username
UAT_PASSWORD=your_uat_password
UAT_BASE_URL=https://uat.example.com

# PRE 环境
PRE_USERNAME=your_pre_username
PRE_PASSWORD=your_pre_password
PRE_BASE_URL=https://pre.example.com

# ==================== 浏览器配置 ====================
# Chrome 驱动路径 (可选，默认自动管理)
# CHROME_DRIVER_PATH=/path/to/chromedriver

# 调试模式端口
CHROME_DEBUG_PORT=9222

# ==================== API 配置 ====================
# API_BASE_URL=https://api.example.com
# API_KEY=your_api_key

# ==================== 报告配置 ====================
# 测试超时时间(秒)
TEST_TIMEOUT=30

# 隐式等待时间(秒)
IMPLICIT_WAIT=10

# 截图保存路径
SCREENSHOT_PATH=./temp/screenshots